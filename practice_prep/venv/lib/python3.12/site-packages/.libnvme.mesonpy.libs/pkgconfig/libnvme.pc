prefix=/usr/local
includedir=${prefix}/include
libdir=${prefix}/lib/x86_64-linux-gnu

Name: libnvme
Description: Manage "libnvme" subsystem devices (Non-volatile Memory Express)
URL: http://github.com/linux-nvme/libnvme/
Version: 1.16.1
Libs: -L${libdir} -lnvme
Libs.private: -lssl -lcrypto
Cflags: -I${includedir}
